{
  "title": "Обзор голосовых сервисов",
  "uid": "voice-services-overview",
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "type": "timeseries",
      "title": "STT p95 задержка (с)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(stt_latency_seconds_bucket[5m])) by (le))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "TTS p95 задержка (с)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(tts_latency_seconds_bucket[5m])) by (le))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Команд в минуту",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "(sum(rate(orc_commands_total[5m])) or vector(0)) * 60",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Ошибок в минуту",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "((sum(rate(stt_errors_total[5m])) or vector(0)) + (sum(rate(tts_errors_total[5m])) or vector(0)) + (sum(rate(orc_errors_total[5m])) or vector(0))) * 60",
          "refId": "A"
        }
      ]
    }
  ]
}
